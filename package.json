{
    "name": "indigenous-australia-the-journey",
    "description": "An interactive 2D exploration game about Aboriginal Australian culture.",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "vite --config vite/config.dev.mjs",
        "build": "vite build --config vite/config.prod.mjs",
        "typecheck": "tsc --noEmit",
        "build:prod": "npm run typecheck && npm run build",
        "preview": "vite preview --config vite/config.prod.mjs"
    },
    "devDependencies": {
        "typescript": "~5.7.2",
        "vite": "^6.3.1"
    },
    "dependencies": {
        "phaser": "^3.90.0",
        "terser": "^5.39.0"
    }
}