    "chapters": [
        {
            "id": "the-campfire-welcome",
            "order": 1,
            "title": "The Campfire Welcome",
            "subtitle": "Chapter I  .  Iuk  .  Eel Season",
            "seasonPresetId": "iuk-dusk",
            "welcomeLines": [
                {
                    "id": "c1-w1",
                    "text": "Welcome. Walk gently, you are on the land of the Kulin Nation.",
                    "mood": "welcome",
                    "pauseGameplay": true
                },
                {
                    "id": "c1-w2",
                    "text": "Tonight the fire is warm and the day is leaving. Come, sit with me for a while.",
                    "mood": "welcome",
                    "pauseGameplay": true
                }
            ],
            "hubLines": [
                {
                    "id": "c1-h1",
                    "text": "Before we share a story I want you to see where food comes from on this Country. Walk with me to the bush tucker trail.",
                    "mood": "teach",
                    "pauseGameplay": false
                }
            ],
            "waypoints": [
                {
                    "id": "c1-wp1",
                    "landmarkId": "bush-tucker",
                    "role": "waypoint",
                    "elderLinesOnArrival": [
                        {
                            "id": "c1-a1",
                            "text": "Here. Murnong, kangaroo grass, wattle seed. Our people have known these plants for tens of thousands of years.",
                            "mood": "teach"
                        },
                        {
                            "id": "c1-a2",
                            "text": "Looking after the land is part of feeding from it. Gentle fire, careful picking. The Country feeds you back.",
                            "mood": "teach"
                        }
                    ],
                    "observationPrompt": "Listen. Can you hear the cicadas settling for the night?"
                },
                {
                    "id": "c1-wp2",
                    "landmarkId": "campfire",
                    "role": "primary",
                    "elderLinesOnArrival": [
                        {
                            "id": "c1-b1",
                            "text": "Back at the fire now. This is where the stories live. Sit. Press E to hear the story of the gathering place.",
                            "mood": "welcome"
                        }
                    ]
                }
            ],
            "closeLines": [
                {
                    "id": "c1-c1",
                    "text": "Good. You have walked with me a little way tonight. The fire will remember you.",
                    "mood": "reflect",
                    "pauseGameplay": true
                }
            ],
            "farewellLines": [
                {
                    "id": "c1-f1",
                    "text": "Thank you for walking with me. Come back another season.",
                    "mood": "farewell",
                    "pauseGameplay": true
                }
            ],
            "citations": [
                {
                    "id": "mv-kulin-seasons",
                    "title": "Kulin Seasonal Calendar",
                    "publisher": "Museums Victoria  .  Bunjilaka",
